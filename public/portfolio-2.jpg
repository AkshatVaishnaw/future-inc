<svg xmlns='http://www.w3.org/2000/svg' width='800' height='500' viewBox='0 0 800 500'>
  <rect width='800' height='500' fill='#2563eb'/>
  <rect width='800' height='500' fill='url(#grad)'/>
  <defs>
    <linearGradient id='grad' x1='0%' y1='0%' x2='100%' y2='100%'>
      <stop offset='0%' style='stop-color:rgba(0,0,0,0.3)'/>
      <stop offset='100%' style='stop-color:rgba(0,0,0,0.7)'/>
    </linearGradient>
  </defs>
  <text x='400' y='230' font-family='Arial' font-size='48' font-weight='bold' fill='white' text-anchor='middle' dominant-baseline='middle'>UrbanEats</text>
  <text x='400' y='290' font-family='Arial' font-size='24' fill='rgba(255,255,255,0.7)' text-anchor='middle' dominant-baseline='middle'>Google Ads + CRM</text>
</svg>